# Copy to .env for live Spotify API calls (optional).
# Create an app at https://developer.spotify.com/dashboard
#
# REQUIRED for --track-id: SPOTIFY_CLIENT_ID + SPOTIFY_CLIENT_SECRET
# NOT required: redirect URI (only for future playlist/user-login features)
#
# Nov 2024+: New apps often get 403 on /v1/audio-features. Use --from-csv instead.
# https://developer.spotify.com/blog/2024-11-27-changes-to-the-web-api

SPOTIFY_CLIENT_ID=d3e6ee03ab2b4f2890597d1ddc66dbbd
SPOTIFY_CLIENT_SECRET=fe8ecb3a3ee140b9b542546fec311b9b

# Optional — playlist creation only, not used by scripts in this folder
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# SPOTIFY_USERNAME=your_spotify_username
